{
	"name": "obsidian-learning-plugin",
	"version": "1.0.0",
	"description": "FSRS-scheduled flashcards inside Obsidian.",
	"main": "main.js",
	"type": "module",
	"scripts": {
		"dev": "concurrently --names esbuild,tailwind --prefix-colors blue,magenta \"node esbuild.config.mjs\" \"npx @tailwindcss/cli -i src/styles.css -o styles.css --watch\"",
		"dev:esbuild": "node esbuild.config.mjs",
		"dev:tailwind": "npx @tailwindcss/cli -i src/styles.css -o styles.css --watch",
		"build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production && npx @tailwindcss/cli -i src/styles.css -o styles.css --minify",
		"version": "node version-bump.mjs && git add manifest.json versions.json",
		"lint": "eslint .",
		"test": "vitest run",
		"test:watch": "vitest"
	},
	"keywords": [],
	"license": "MIT",
	"devDependencies": {
		"@codemirror/commands": "^6.10.3",
		"@codemirror/language": "^6.12.3",
		"@codemirror/state": "^6.6.0",
		"@codemirror/view": "^6.43.0",
		"@eslint/js": "9.30.1",
		"@eslint/json": "0.14.0",
		"@tailwindcss/cli": "^4.2.4",
		"@types/node": "^22.19.17",
		"@types/react": "^19.2.14",
		"@types/react-dom": "^19.2.3",
		"concurrently": "^9.2.1",
		"esbuild": "0.25.5",
		"eslint-plugin-obsidianmd": "0.1.9",
		"globals": "14.0.0",
		"jiti": "2.6.1",
		"tailwindcss": "^4.2.4",
		"tslib": "2.4.0",
		"typescript": "^5.8.3",
		"typescript-eslint": "8.35.1",
		"vitest": "^4.1.5"
	},
	"dependencies": {
		"@codemirror/autocomplete": "^6.20.2",
		"@codemirror/lang-markdown": "^6.5.0",
		"@lezer/markdown": "^1.6.3",
		"obsidian": "latest",
		"react": "^19.2.5",
		"react-dom": "^19.2.5",
		"ts-fsrs": "^5.3.2",
		"zod": "^4.3.6",
		"zustand": "^5.0.12"
	}
}
