{
	"name": "obsidian-learning-plugin",
	"version": "0.1.0",
	"description": "FSRS-scheduled flashcards inside Obsidian.",
	"main": "main.js",
	"type": "module",
	"scripts": {
		"dev": "concurrently --names esbuild,tailwind --prefix-colors blue,magenta \"node esbuild.config.mjs\" \"npx @tailwindcss/cli -i src/styles.css -o styles.css --watch\"",
		"dev:esbuild": "node esbuild.config.mjs",
		"dev:tailwind": "npx @tailwindcss/cli -i src/styles.css -o styles.css --watch",
		"build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production && npx @tailwindcss/cli -i src/styles.css -o styles.css --minify",
		"version": "node version-bump.mjs && git add manifest.json versions.json",
		"lint": "eslint ."
	},
	"keywords": [],
	"license": "0-BSD",
	"devDependencies": {
		"@eslint/js": "9.30.1",
		"@tailwindcss/cli": "^4.2.4",
		"@types/node": "^16.11.6",
		"@types/react": "^19.2.14",
		"@types/react-dom": "^19.2.3",
		"concurrently": "^9.2.1",
		"esbuild": "0.25.5",
		"eslint-plugin-obsidianmd": "0.1.9",
		"globals": "14.0.0",
		"jiti": "2.6.1",
		"tailwindcss": "^4.2.4",
		"tslib": "2.4.0",
		"typescript": "^5.8.3",
		"typescript-eslint": "8.35.1"
	},
	"dependencies": {
		"obsidian": "latest",
		"react": "^19.2.5",
		"react-dom": "^19.2.5",
		"ts-fsrs": "^5.3.2",
		"zod": "^4.3.6",
		"zustand": "^5.0.12"
	}
}
